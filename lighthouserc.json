{
  "ci": {
    "collect": {
      "startServerCommand": "npx serve out -l 4174 -L",
      "startServerReadyPattern": "Accepting connections",
      "url": [
        "http://localhost:4174/",
        "http://localhost:4174/about",
        "http://localhost:4174/work",
        "http://localhost:4174/writing",
        "http://localhost:4174/contact"
      ],
      "settings": {
        "preset": "desktop"
      },
      "numberOfRuns": 3
    },
    "assert": {
      "assertions": {
        "categories:performance": [
          "warn",
          {
            "minScore": 0.85
          }
        ],
        "categories:accessibility": [
          "error",
          {
            "minScore": 0.95
          }
        ],
        "categories:best-practices": [
          "warn",
          {
            "minScore": 0.9
          }
        ],
        "categories:seo": [
          "error",
          {
            "minScore": 0.95
          }
        ],
        "largest-contentful-paint": [
          "error",
          {
            "maxNumericValue": 3000,
            "aggregationMethod": "median"
          }
        ],
        "cumulative-layout-shift": [
          "error",
          {
            "maxNumericValue": 0.1,
            "aggregationMethod": "median"
          }
        ],
        "total-blocking-time": [
          "error",
          {
            "maxNumericValue": 300,
            "aggregationMethod": "median"
          }
        ]
      }
    }
  }
}
